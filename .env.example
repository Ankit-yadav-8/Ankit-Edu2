# ─── Copy this file to ".env" and fill in your real values ───

# Server
PORT=5000

# MongoDB Atlas connection string.
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Cluster > Connect > Drivers > copy the string, then replace <username>/<password>/<dbname>.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rgreenlogic?retryWrites=true&w=majority

# Secret used to sign login tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_string

# OPTIONAL — enables the "real" AI visitor assistant (Claude).
# Without this, the assistant falls back to a built-in knowledge base and still works.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
