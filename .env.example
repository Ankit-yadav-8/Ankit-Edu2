# ─── Copy this file to ".env" and fill in your real values ───

# ─── Backend (Express on Render) ───────────────────────────
PORT=5000

# Supabase project settings → Data API / API Keys.
# SERVICE ROLE key bypasses Row Level Security — keep it server-side ONLY.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# Password for the /admin panel. Checked server-side ONLY — never shipped to the
# browser. Set the real value in Render's env vars (and your local .env), NOT here.
ADMIN_PASSWORD=change_this_to_a_strong_admin_password

# Comma-separated frontends allowed to call this API (CORS).
ALLOWED_ORIGINS=https://www.rgreenlogic.com,https://rgreenlogic.com,http://localhost:5173

# OPTIONAL — enables the Claude visitor assistant. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Frontend (Vite) ───────────────────────────────────────
# Empty for local dev. For the deployed build, set to your Render backend URL.
VITE_API_URL=
